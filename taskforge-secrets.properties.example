# Local developer secrets for TaskForge
# Copy this file to `taskforge-secrets.properties` (same folder) and fill in values.
# This file is safe to commit as an example; `taskforge-secrets.properties` is ignored by git.

# Option A (recommended): provide variables referenced by application.properties
TASKFORGE_DB_USER=root
TASKFORGE_DB_PASS=your_password_here

# Option B (also works): override Spring datasource keys directly
# spring.datasource.username=root
# spring.datasource.password=your_password_here
